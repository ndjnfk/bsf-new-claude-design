# Copy to .env.local and override as needed (.env.local is git-ignored).
#
# API base URL. Prod/default is the relative '/api/' (served same-origin). For a
# remote backend in dev, set the full URL, e.g. https://bsftest.co/api/
VITE_API_BASE=/api/

# Socket server URL (Angular default '/'). Realtime is wired in a later phase.
VITE_SOCKET_URL=/

# Socket.IO handshake path (preserved exactly from Angular).
VITE_SOCKET_PATH=/api/socket.io

# Geolocation endpoint used to enrich the login payload (best-effort).
VITE_GEO_URL=https://ipapi.co/json
