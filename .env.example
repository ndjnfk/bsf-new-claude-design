# Copy to .env and adjust. docker-compose and the Go API both read these.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=bsf2020
MYSQL_USER=bsf
MYSQL_PASSWORD=bsf
MYSQL_PORT=3306

# --- MongoDB ---
MONGO_USER=bsf
MONGO_PASSWORD=bsf
MONGO_DATABASE=bsf2020
MONGO_PORT=27017

# --- Redis ---
REDIS_PORT=6379

# --- API (host run) ---
APP_ENV=local
HTTP_PORT=8080
# When the API runs on the host against compose DBs, use localhost:
MYSQL_DSN=bsf:bsf@tcp(localhost:3306)/bsf2020?parseTime=true&charset=utf8mb4&loc=UTC
MONGO_URI=mongodb://bsf:bsf@localhost:27017/bsf2020?authSource=admin
MONGO_DB=bsf2020
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# --- Auth ---
JWT_SECRET=change-me-in-prod

# --- Matching engine ---
# Empty = in-process Go engine. Set to use the dedicated Rust service:
#   ENGINE_URL=http://localhost:9090
ENGINE_URL=
ENGINE_PORT=9090

# --- Bootstrap Super Duper Admin (created on first start if missing) ---
SDA_USERNAME=bsf
SDA_PASSWORD=Bsf@12345
